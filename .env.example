OPENROUTER_API_KEY=
JINA_API_KEY=

# Agent models (all routed through OpenRouter)
KAI_ROOT_MODEL=anthropic/claude-opus-4.6
KAI_ANALYZER_MODEL=minimax/minimax-m2.5
KAI_VERIFIER_MODEL=anthropic/claude-opus-4.5
KAI_FIXER_MODEL=openai/gpt-5.2
KAI_RESEARCHER_MODEL=anthropic/claude-opus-4.6
KAI_POC_AUDITOR_MODEL=openai/gpt-4.1-mini
KAI_SETUP_MODEL=anthropic/claude-opus-4.5

# Model used by llm_query() inside sub-agent REPLs
KAI_QUERY_MODEL=openai/gpt-5.2

# Agent iteration budgets
KAI_ROOT_ITERS=45
KAI_ANALYZER_ITERS=30
KAI_VERIFIER_ITERS=30
KAI_FIXER_ITERS=25
KAI_RESEARCHER_ITERS=15
KAI_POC_AUDITOR_ITERS=5
KAI_SETUP_ITERS=30

# Iteration extension (root agent only)
KAI_MAX_EXTEND_ITERS=15
KAI_EXTEND_ITERS_PER_CANDIDATE=5

# Logging
KAI_LOG_STRUCTURED=0
KAI_LOG_PREVIEW_CHARS=500

# Rollout saving
KAI_SAVE_ROLLOUTS=0
KAI_ROLLOUT_AGENTS=

# Timeouts (seconds)
KAI_EXEC_TIMEOUT=1200
KAI_ANALYZER_TIMEOUT=900
KAI_SOCKET_TIMEOUT=900
KAI_SHELL_TIMEOUT=300