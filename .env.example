# LLM provider credentials.
# Use OPENROUTER_API_KEY with KAI_BACKEND=openrouter.
# Use OPENAI_API_KEY with KAI_BACKEND=openai.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
# OPEN_AI_API_KEY=  # Optional alias for OPENAI_API_KEY.

# Optional: web search and URL reading for the researcher agent.
JINA_API_KEY=

# Optional: OpenRouter attribution headers shown in OpenRouter usage.
# Defaults identify this project as kai-security.
# OpenRouter derives the app icon from the favicon of OPENROUTER_APP_URL.
# OPENROUTER_APP_URL=https://kai.dria.co/
# OPENROUTER_APP_TITLE=kai-security
# OPENROUTER_APP_CATEGORIES=cli-agent,programming-app

# Agent models (all routed through OpenRouter)
KAI_ROOT_MODEL=anthropic/claude-opus-4.6
KAI_ANALYZER_MODEL=minimax/minimax-m2.5
KAI_VERIFIER_MODEL=anthropic/claude-opus-4.5
KAI_FIXER_MODEL=openai/gpt-5.2
KAI_RESEARCHER_MODEL=anthropic/claude-opus-4.6
KAI_POC_AUDITOR_MODEL=openai/gpt-4.1-mini
KAI_SETUP_MODEL=anthropic/claude-opus-4.5

# Backend selection.
# Supported values: openrouter, openai
KAI_BACKEND=openrouter

# Optional per-agent backend overrides.
# KAI_ROOT_BACKEND=openai
# KAI_ANALYZER_BACKEND=openai
# KAI_VERIFIER_BACKEND=openai
# KAI_FIXER_BACKEND=openai
# KAI_CRITIC_BACKEND=openai
# KAI_RESEARCHER_BACKEND=openai
# KAI_SETUP_BACKEND=openai
# KAI_CHAIN_BACKEND=openai
# KAI_PATCH_ASSEMBLER_BACKEND=openai
# KAI_POC_AUDITOR_BACKEND=openai

# Model used by llm_query() inside sub-agent REPLs
KAI_QUERY_MODEL=openai/gpt-5.2

# Optional model overrides.
# Comment out the active OpenRouter examples above to use backend-specific
# defaults from the code instead.
# For OpenRouter, use provider-prefixed IDs such as anthropic/claude-opus-4.5.
# For direct OpenAI, use OpenAI model IDs such as gpt-5.2.
# KAI_ROOT_MODEL=anthropic/claude-opus-4.5
# KAI_ANALYZER_MODEL=minimax/minimax-m2.5
# KAI_VERIFIER_MODEL=openai/gpt-5.2
# KAI_FIXER_MODEL=openai/gpt-5.2
# KAI_CRITIC_MODEL=anthropic/claude-opus-4.5
# KAI_RESEARCHER_MODEL=minimax/minimax-m2.5
# KAI_SETUP_MODEL=minimax/minimax-m2.5
# KAI_CHAIN_MODEL=anthropic/claude-opus-4.5
# KAI_PATCH_ASSEMBLER_MODEL=openai/gpt-4.1
# KAI_POC_AUDITOR_MODEL=openai/gpt-4.1-mini
# KAI_QUERY_MODEL=openai/gpt-5.2

# Agent iteration budgets.
KAI_ROOT_ITERS=45
KAI_ANALYZER_ITERS=30
KAI_VERIFIER_ITERS=30
KAI_FIXER_ITERS=25
KAI_CRITIC_ITERS=10
KAI_RESEARCHER_ITERS=15
KAI_POC_AUDITOR_ITERS=5
KAI_CHAIN_ITERS=20
KAI_PATCH_ASSEMBLER_ITERS=15
KAI_SETUP_ITERS=30

# Iteration extension (root agent only).
KAI_MAX_EXTEND_ITERS=15
KAI_EXTEND_ITERS_PER_CANDIDATE=5

# Logging.
KAI_LOG_STRUCTURED=0
KAI_LOG_PREVIEW_CHARS=500

# Rollout saving.
KAI_SAVE_ROLLOUTS=0
KAI_ROLLOUT_AGENTS=

# Timeouts (seconds).
KAI_EXEC_TIMEOUT=1200
KAI_ANALYZER_TIMEOUT=900
KAI_SOCKET_TIMEOUT=900
KAI_SHELL_TIMEOUT=300

# Per-iteration caps (shared RLM; see src/ra/core/rlm.py).
# Wall-clock cap (seconds) on a single iteration before the harness truncates.
# 0 disables the cap. Default in code is 600s; production uses higher.
KAI_ITER_WALL_CAP=1800
# Hard cap on how many code blocks per iteration the harness will execute.
# 0 disables. Default 6.
KAI_MAX_BLOCKS_PER_ITER=6
# Per-LLM-call request timeout (seconds).
KAI_LLM_REQUEST_TIMEOUT_S=900

# ---------------------------------------------------------------------------
# Benchmark worker (Railway deploy — `python -m evaluation.worker`)
# ---------------------------------------------------------------------------
# These vars are consumed by the worker loop + benchmark adapters. Only set
# them when running the worker; ignored by `python -m kai.main pipeline ...`.

# Which adapter to load. One of: noop | cybergym | bountybench | evmbench
BENCHMARK_ADAPTER=cybergym
# Adapter-specific JSON config. Examples:
#   cybergym: {"dataset_source":"huggingface","submit":false}
#   evmbench: {"setup_mode":"auto"}
#   bountybench: {"mode":"detect"}
BENCHMARK_CONFIG={"dataset_source":"huggingface","submit":false}
# Per-task wall-clock timeout before the worker kills the pipeline subprocess.
# cybergym typically 10800s (3h), evmbench typically 14400s (4h).
BENCHMARK_TASK_TIMEOUT_S=10800
# Optional extra args passed to `kai.main pipeline`. JSON array of strings.
# Example for evmbench fast-path: ["--skip-fixer","--no-iterative"]
# BENCHMARK_PIPELINE_ARGS=[]
# Optional: limit a replica to only claim tasks from a single run_id.
# BENCHMARK_RUN_ID=
# Optional: override the worker's output root (default: output/bench).
# BENCHMARK_OUTPUT_ROOT=
# Optional: seconds the worker sleeps between claim attempts (default 5).
# BENCHMARK_POLL_SECONDS=5
# Optional: auto-exit the worker after N idle seconds (default: never).
# BENCHMARK_IDLE_EXIT_AFTER=
# Optional: JSON dict of env overrides forwarded to every pipeline subprocess.
# BENCHMARK_ENV_OVERRIDES={}

# Tells shared core (src/ra/, src/kai/) which benchmark is active, so
# cybergym-only behavior (spawn-gate, harness-tool injection, cwd lock)
# activates. Typically matches BENCHMARK_ADAPTER on cybergym workers.
KAI_BENCHMARK=cybergym

# Postgres queue (auto-wired from Railway Postgres plugin). The worker reads
# this to claim tasks from `bench_tasks` + write results to `bench_scores`.
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/railway

# ---------------------------------------------------------------------------
# Cybergym strict-verify harness
# ---------------------------------------------------------------------------
# URL of the cybergym submission server (e.g. ngrok tunnel to a local Docker
# fuzzer). When set on a worker with KAI_BENCHMARK=cybergym, the verifier
# sub-agent gets a `submit_to_cybergym_harness(poc_b64)` tool that POSTs PoC
# bytes to {url}/submit-vul and returns the real exit_code/output.
# When unset, the verifier falls back to soft-verified bookkeeping.
# ngrok free-tier subdomains rotate on reconnect — update via
#   railway variables --service kai-bench-cybergym-v2 \
#     --set KAI_CYBERGYM_HARNESS_URL=https://<new-subdomain>.ngrok-free.app
# then redeploy. See docs/railway-deploy.md for the full rotation procedure.
KAI_CYBERGYM_HARNESS_URL=https://<your-ngrok-subdomain>.ngrok-free.app
