# LLM provider credentials.
# Use OPENROUTER_API_KEY with KAI_BACKEND=openrouter.
# Use OPENAI_API_KEY with KAI_BACKEND=openai.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
# OPEN_AI_API_KEY=  # Optional alias for OPENAI_API_KEY.

# Optional: web search and URL reading for the researcher agent.
JINA_API_KEY=

# Optional: OpenRouter attribution headers shown in OpenRouter usage.
# Defaults identify this project as kai-security.
# OpenRouter derives the app icon from the favicon of OPENROUTER_APP_URL.
# OPENROUTER_APP_URL=https://kai.dria.co/
# OPENROUTER_APP_TITLE=kai-security
# OPENROUTER_APP_CATEGORIES=cli-agent,programming-app

# Agent models (all routed through OpenRouter)
KAI_ROOT_MODEL=anthropic/claude-opus-4.6
KAI_ANALYZER_MODEL=minimax/minimax-m2.5
KAI_VERIFIER_MODEL=anthropic/claude-opus-4.5
KAI_FIXER_MODEL=openai/gpt-5.2
KAI_RESEARCHER_MODEL=anthropic/claude-opus-4.6
KAI_POC_AUDITOR_MODEL=openai/gpt-4.1-mini
KAI_SETUP_MODEL=anthropic/claude-opus-4.5

# Backend selection.
# Supported values: openrouter, openai
KAI_BACKEND=openrouter

# Optional per-agent backend overrides.
# KAI_ROOT_BACKEND=openai
# KAI_ANALYZER_BACKEND=openai
# KAI_VERIFIER_BACKEND=openai
# KAI_FIXER_BACKEND=openai
# KAI_CRITIC_BACKEND=openai
# KAI_RESEARCHER_BACKEND=openai
# KAI_SETUP_BACKEND=openai
# KAI_CHAIN_BACKEND=openai
# KAI_PATCH_ASSEMBLER_BACKEND=openai
# KAI_POC_AUDITOR_BACKEND=openai

# Model used by llm_query() inside sub-agent REPLs
KAI_QUERY_MODEL=openai/gpt-5.2

# Optional model overrides.
# Comment out the active OpenRouter examples above to use backend-specific
# defaults from the code instead.
# For OpenRouter, use provider-prefixed IDs such as anthropic/claude-opus-4.5.
# For direct OpenAI, use OpenAI model IDs such as gpt-5.2.
# KAI_ROOT_MODEL=anthropic/claude-opus-4.5
# KAI_ANALYZER_MODEL=minimax/minimax-m2.5
# KAI_VERIFIER_MODEL=openai/gpt-5.2
# KAI_FIXER_MODEL=openai/gpt-5.2
# KAI_CRITIC_MODEL=anthropic/claude-opus-4.5
# KAI_RESEARCHER_MODEL=minimax/minimax-m2.5
# KAI_SETUP_MODEL=minimax/minimax-m2.5
# KAI_CHAIN_MODEL=anthropic/claude-opus-4.5
# KAI_PATCH_ASSEMBLER_MODEL=openai/gpt-4.1
# KAI_POC_AUDITOR_MODEL=openai/gpt-4.1-mini
# KAI_QUERY_MODEL=openai/gpt-5.2

# Agent iteration budgets.
KAI_ROOT_ITERS=45
KAI_ANALYZER_ITERS=30
KAI_VERIFIER_ITERS=30
KAI_FIXER_ITERS=25
KAI_CRITIC_ITERS=10
KAI_RESEARCHER_ITERS=15
KAI_POC_AUDITOR_ITERS=5
KAI_CHAIN_ITERS=20
KAI_PATCH_ASSEMBLER_ITERS=15
KAI_SETUP_ITERS=30

# Iteration extension (root agent only).
KAI_MAX_EXTEND_ITERS=15
KAI_EXTEND_ITERS_PER_CANDIDATE=5

# Logging.
KAI_LOG_STRUCTURED=0
KAI_LOG_PREVIEW_CHARS=500

# Rollout saving.
KAI_SAVE_ROLLOUTS=0
KAI_ROLLOUT_AGENTS=

# Timeouts (seconds).
KAI_EXEC_TIMEOUT=1200
KAI_ANALYZER_TIMEOUT=900
KAI_SOCKET_TIMEOUT=900
KAI_SHELL_TIMEOUT=300
